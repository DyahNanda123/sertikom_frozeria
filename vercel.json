{
    "version": 2,
    "nodes": {
        "api/*.php": { "runtime": "vercel-php@0.7.0" }
    },
    "routes": [
        {
            "src": "/(css|js|images|favicon.ico)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}